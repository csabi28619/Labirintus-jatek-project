<Window x:Class="LabyrinthEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LabyrinthEditor.Views"
        Title="Labyrinth Editor 2000"
        Height="720" Width="1200"
        MinHeight="500" MinWidth="800"
        Background="#0A0A12"
        FontFamily="Consolas">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary"   Color="#0A0A12"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#14141E"/>
        <SolidColorBrush x:Key="BgControl"   Color="#1E1E2E"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#C83232"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#707080"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2A2A3A"/>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#E0E0E0"/>
            <Setter Property="BorderBrush"     Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="2,1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#2A2A3E"/>
                                <Setter Property="BorderBrush" Value="#C83232"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#C83232"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#C83232"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,10,0,4"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
        </Style>

        <Style x:Key="ValidationText" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#E0E0E0"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ MENU BAR ══════════════════════════════════════════════════ -->
        <Menu Grid.Row="0" Background="#0A0A12" Foreground="#E0E0E0"
              BorderBrush="#2A2A3A" BorderThickness="0,0,0,1">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Background" Value="#0A0A12"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                </Style>
            </Menu.Resources>
            <MenuItem x:Name="MenuFile" Header="Fájl">
                <MenuItem x:Name="MenuNew"    Header="Új térkép"      InputGestureText="Ctrl+N" Click="MenuNew_Click"/>
                <MenuItem x:Name="MenuOpen"   Header="Megnyitás"      InputGestureText="Ctrl+O" Click="MenuOpen_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuSave"   Header="Mentés"         InputGestureText="Ctrl+S" Click="MenuSave_Click"/>
                <MenuItem x:Name="MenuSaveAs" Header="Mentés másként"                            Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuExit"   Header="Kilépés"                                   Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuEdit" Header="Szerkesztés">
                <MenuItem x:Name="MenuUndo" Header="Visszavonás" InputGestureText="Ctrl+Z" Click="MenuUndo_Click"/>
                <MenuItem x:Name="MenuRedo" Header="Újra"        InputGestureText="Ctrl+Y" Click="MenuRedo_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuView" Header="Nézet">
                <MenuItem x:Name="MenuGrid"       Header="Rács megjelenítése"   IsCheckable="True" IsChecked="True" Click="MenuGrid_Click"/>
                <MenuItem x:Name="MenuHighlights" Header="Konzisztencia jelölők" IsCheckable="True" IsChecked="True" Click="MenuHighlights_Click"/>
                <MenuItem x:Name="MenuReset"      Header="Nézet visszaállítása"                                     Click="MenuReset_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuValidate" Header="Ellenőrzés" Click="MenuValidate_Click"/>
        </Menu>

        <!-- ═══ TOOLBAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#14141E"
                BorderBrush="#2A2A3A" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnNew"      Style="{StaticResource ToolButton}" Click="MenuNew_Click"/>
                <Button x:Name="BtnOpen"     Style="{StaticResource ToolButton}" Click="MenuOpen_Click"/>
                <Button x:Name="BtnSave"     Style="{StaticResource ToolButton}" Click="MenuSave_Click"/>
                <Separator Width="1" Background="#2A2A3A" Margin="6,0"/>
                <Button x:Name="BtnUndo"     Style="{StaticResource ToolButton}" Click="MenuUndo_Click"/>
                <Button x:Name="BtnRedo"     Style="{StaticResource ToolButton}" Click="MenuRedo_Click"/>
                <Separator Width="1" Background="#2A2A3A" Margin="6,0"/>
                <Button x:Name="BtnValidate" Style="{StaticResource ToolButton}" Click="MenuValidate_Click"/>
                <Separator Width="1" Background="#2A2A3A" Margin="6,0"/>
                <Button x:Name="BtnLanguage" Style="{StaticResource ToolButton}" Click="BtnLanguage_Click"/>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN AREA ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="165"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="210"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="#14141E"
                    BorderBrush="#2A2A3A" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,8">

                        <TextBlock x:Name="LblSectionTool" Style="{StaticResource SectionHeader}"/>

                        <Button x:Name="BtnToolCorridor"    Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Click="BtnToolCorridor_Click"/>
                        <Button x:Name="BtnToolRoom"        Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Click="BtnToolRoom_Click"/>
                        <Button x:Name="BtnToolPlayerStart" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Click="BtnToolPlayerStart_Click"/>
                        <Button x:Name="BtnToolEnemy"       Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Click="BtnToolEnemy_Click"/>
                        <Button x:Name="BtnToolVoid"        Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Click="BtnToolVoid_Click"/>

                        <!-- Enemy hint -->
                        <Border x:Name="EnemyHintPanel" Visibility="Collapsed"
                                Background="#1A0A0A" BorderBrush="#C83232"
                                BorderThickness="1" CornerRadius="3" Margin="0,6,0,0" Padding="6,4">
                            <StackPanel>
                                <TextBlock x:Name="LblEnemyAdd"    Foreground="#FF8080" FontFamily="Consolas" FontSize="10"/>
                                <TextBlock x:Name="LblEnemyRemove" Foreground="#FF8080" FontFamily="Consolas" FontSize="10"/>
                                <TextBlock x:Name="LblEnemyMax"    Foreground="#808080" FontFamily="Consolas" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="LblSectionCorridor" Style="{StaticResource SectionHeader}"/>
                        <WrapPanel x:Name="PalettePanel"/>

                        <TextBlock x:Name="LblSectionZoom" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="−" Width="30" Style="{StaticResource ToolButton}" Click="BtnZoomOut_Click"/>
                            <TextBlock x:Name="TxtZoom" Text="100%" Width="50"
                                       Foreground="#E0E0E0" FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center" TextAlignment="Center"/>
                            <Button Content="+" Width="30" Style="{StaticResource ToolButton}" Click="BtnZoomIn_Click"/>
                        </StackPanel>
                        <Button x:Name="BtnZoomReset" Style="{StaticResource ToolButton}"
                                HorizontalAlignment="Stretch" Click="MenuReset_Click" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── CENTER: Map Canvas ────────────────────────────────────── -->
            <Border Grid.Column="1" Background="#000000" ClipToBounds="True">
                <local:MapCanvas x:Name="TheMapCanvas"/>
            </Border>

            <!-- ── RIGHT PANEL ───────────────────────────────────────────── -->
            <Border Grid.Column="2" Background="#14141E"
                    BorderBrush="#2A2A3A" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,8">

                        <TextBlock x:Name="LblSectionMapInfo" Style="{StaticResource SectionHeader}"/>
                        <TextBlock x:Name="InfoName"    Style="{StaticResource ValidationText}"/>
                        <TextBlock x:Name="InfoSize"    Style="{StaticResource ValidationText}"/>
                        <TextBlock x:Name="InfoRooms"   Style="{StaticResource ValidationText}"/>
                        <TextBlock x:Name="InfoExits"   Style="{StaticResource ValidationText}"/>
                        <TextBlock x:Name="InfoEnemies" Style="{StaticResource ValidationText}"/>

                        <TextBlock x:Name="LblSectionValidate" Style="{StaticResource SectionHeader}"/>
                        <Button x:Name="BtnRunValidation" Style="{StaticResource ToolButton}"
                                HorizontalAlignment="Stretch" Click="MenuValidate_Click"/>

                        <!-- Highlight legend -->
                        <Border Background="#0F0F18" BorderBrush="#2A2A3A"
                                BorderThickness="1" CornerRadius="3"
                                Margin="0,6,0,0" Padding="6,4">
                            <StackPanel>
                                <TextBlock x:Name="LblLegendTitle"
                                           Foreground="#707080" FontSize="9"
                                           FontFamily="Consolas" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="14" Height="14" CornerRadius="2"
                                            Background="#A0FF1E1E" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="LblLegendInvalid"
                                               Foreground="#C0C0C0" FontSize="10" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="14" Height="14" CornerRadius="2"
                                            Background="#A0FF8C00" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="LblLegendIsolated"
                                               Foreground="#C0C0C0" FontSize="10" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <Border Width="14" Height="14" CornerRadius="2"
                                            Background="#7800DCFF" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="LblLegendExit"
                                               Foreground="#C0C0C0" FontSize="10" FontFamily="Consolas"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="ValidationList" Margin="0,6,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource ValidationText}" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="LblSectionControls" Style="{StaticResource SectionHeader}"/>
                        <TextBlock x:Name="LblControlsText"
                                   Style="{StaticResource ValidationText}"
                                   Foreground="#505060"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0A0A12"
                BorderBrush="#2A2A3A" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock x:Name="StatusBar" Foreground="#505060"
                       FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</Window>
