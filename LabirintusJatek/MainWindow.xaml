<Window x:Class="LabirintusJatek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Labirintus" Height="700" Width="900"
        KeyDown="Window_KeyDown">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="10">

            <Button Content="Betöltés"
                    Width="100"
                    Margin="5"
                    Click="LoadMaze_Click"/>

            <Button Content="Mentés"
                    Width="100"
                    Margin="5"
                    Click="Save_Click"/>

            <Button Content="Visszatöltés"
                    Width="100"
                    Margin="5"
                    Click="LoadSave_Click"/>

            <ComboBox Name="LanguageBox"
                      Width="120"
                      SelectionChanged="LanguageBox_SelectionChanged">
                <ComboBoxItem Content="Magyar"/>
                <ComboBoxItem Content="English"/>
            </ComboBox>

            <TextBlock Name="InfoText"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="16"/>

        </StackPanel>

        <ScrollViewer>
            <UniformGrid Name="MazeGrid" Columns="1" Rows="1"/>
        </ScrollViewer>

    </DockPanel>
</Window>